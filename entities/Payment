{
  "name": "Payment",
  "type": "object",
  "properties": {
    "invoice_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "payment_date": {
      "type": "string",
      "format": "date"
    },
    "method": {
      "type": "string",
      "enum": [
        "ACH",
        "Wire",
        "Check",
        "Credit Card",
        "Other"
      ],
      "default": "ACH"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "invoice_id",
    "amount"
  ]
}