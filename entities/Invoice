{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "invoice_number": {
      "type": "string",
      "description": "Auto-generated INV-YYYY-XXXX"
    },
    "submission_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "candidate_name": {
      "type": "string"
    },
    "bill_rate": {
      "type": "number"
    },
    "period_start": {
      "type": "string",
      "format": "date"
    },
    "period_end": {
      "type": "string",
      "format": "date"
    },
    "total_amount": {
      "type": "number"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "amount_paid": {
      "type": "number",
      "default": 0
    },
    "balance": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Sent",
        "Paid",
        "Overdue"
      ],
      "default": "Draft"
    }
  },
  "required": [
    "client_id",
    "total_amount"
  ]
}